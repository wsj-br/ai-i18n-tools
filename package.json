{
  "name": "ai-i18n-tools",
  "version": "1.0.0",
  "description": "Unified internationalization toolkit for Node.js apps and documentation with AI translation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    }
  },
  "bin": {
    "ai-i18n-tools": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-edit-cache-app.mjs",
    "dev": "node scripts/copy-edit-cache-app.mjs && tsc --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist/",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm test",
    "i18n:extract": "ai-i18n-tools extract",
    "i18n:sync": "ai-i18n-tools sync",
    "i18n:translate": "ai-i18n-tools translate-docs",
    "i18n:cleanup": "ai-i18n-tools cleanup",
    "sync-docs": "node scripts/sync-docs-to-nextjs-example.mjs",
    "update-all": "pnpm build && ai-i18n-tools cleanup && cd examples/console-app && ai-i18n-tools cleanup && cd ../nextjs-app && ai-i18n-tools cleanup",
    "clean-temp": "find . \\( -name '*.log' -o -name 'cache.db.backup*.sqlite' \\) -print && read -p 'Delete these files? (y/n) ' ans && [ \"$ans\" = \"y\" ] && find . \\( -name '*.log' -o -name 'cache.db.backup*.sqlite' \\) -delete"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "react",
    "docusaurus",
    "openrouter",
    "localization",
    "multilingual",
    "cache",
    "cli"
  ],
  "author": "Waldemar Scudeller Jr.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wsj-br/ai-i18n-tools.git"
  },
  "bugs": {
    "url": "https://github.com/wsj-br/ai-i18n-tools/issues"
  },
  "homepage": "https://github.com/wsj-br/ai-i18n-tools#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "csv-parse": "^6.2.1",
    "express": "^5.2.1",
    "gray-matter-es": "^0.2.1",
    "i18next-scanner": "^4.6.0",
    "ignore": "^7.0.5",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "@types/unist": "^3.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "github-slugger": "^2.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.16.0",
    "pnpm": ">=10.33.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "glob": "^13.0.6",
    "test-exclude": "^8.0.0"
  }
}
