{
  "name": "ai-i18n-tools",
  "version": "1.0.0",
  "description": "Unified internationalization toolkit for Node.js apps and documentation with AI translation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    }
  },
  "bin": {
    "ai-i18n-tools": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-edit-cache-app.mjs",
    "dev": "node scripts/copy-edit-cache-app.mjs && tsc --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist/",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm test",
    "sync-docs:nextjs-example": "node scripts/sync-docs-to-nextjs-example.mjs"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "react",
    "docusaurus",
    "openrouter",
    "localization",
    "multilingual",
    "cache",
    "cli"
  ],
  "author": "Waldemar Scudeller Jr.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wsj-br/ai-i18n-tools.git"
  },
  "bugs": {
    "url": "https://github.com/wsj-br/ai-i18n-tools/issues"
  },
  "homepage": "https://github.com/wsj-br/ai-i18n-tools#readme",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "csv-parse": "^6.2.1",
    "express": "^5.2.1",
    "figlet": "^1.11.0",
    "gray-matter": "^4.0.3",
    "i18next-scanner": "^4.6.0",
    "ignore": "^7.0.5",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/figlet": "^1.7.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "eslint": "^10.2.0",
    "github-slugger": "^2.0.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.16.0",
    "pnpm": ">=10.33.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "glob": "^13.0.6",
    "test-exclude": "^8.0.0"
  }
}
